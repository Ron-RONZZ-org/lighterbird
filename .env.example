# ── lighterbird environment variables ─────────────────────────────────────
#
# Copy this file to .dev (gitignored) and fill in your real credentials.
# Never commit real credentials to version control.
#
# These variables are used by the seed-data generator (lighterbird-dev --seed)
# and E2E tests. The server itself does NOT read .env files — credentials
# are stored in the system keyring at account setup time.

# Email account #1 — used for seeding
TEST_EMAIL_1="alice@example.com"
TEST_EMAIL_1_PASS="your-email-password"

# Email account #2 — used for multi-account tests
TEST_EMAIL_2="bob@example.com"
TEST_EMAIL_2_PASS="your-other-email-password"

# CalDAV calendar URL + credentials (Nextcloud, ownCloud, etc.)
TEST_CALENDAR_URL="https://calendar.example.com/remote.php/dav/calendars/user/test/"
TEST_CALENDAR_USERNAME="user@example.com"
TEST_CALENDAR_PASSWORD="your-calendar-password"

# LLM API key (DeepSeek / OpenAI-compatible)
TEST_DEEPSEEK_APIKEY="sk-your-api-key-here"

# Optional paths for seeding user profiles & contacts
# TEST_USERPROFILE_PATH="./test-profile.toml"
# TEST_CONTACT_PATH="./test-contact.toml"
